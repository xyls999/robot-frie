# Ignore everything by default.
*

# Keep the repository rules and submission entrypoint.
!.gitignore
!predict.py

# Keep the two PaddleDetection code folders requested for this repo.
!PaddleDetection/
!PaddleDetection/**
!PaddleDetection_train/
!PaddleDetection_train/**

# Do not commit generated caches.
__pycache__/
*.py[cod]
*.pyo

# Do not commit local training data, checkpoints, logs, or exported artifacts.
PaddleDetection_train/dataset/
PaddleDetection_train/output/
PaddleDetection_train/output_eval/
PaddleDetection_train/output_inference/
PaddleDetection_train/vdl_log_dir/
PaddleDetection_train/bbox.json

# Do not commit nested repository metadata.
PaddleDetection_train/.git/

# Do not commit packaged submissions or local result files.
/*.zip
/result.json
/analysis/
/A_train/
/model/
/scripts/

# Keep the current evaluated submission artifacts.
!/model/
!/model/infer_cfg.yml
!/model/model.pdmodel
!/model/model.pdiparams
!submission.zip
!submission_firedetect_736_clean_epoch140_thr040_080_020_nms_area.zip
!CURRENT_SUBMISSION.md
!start_generalize_500e_704_training.bat
!start_clean_180e_736_kfold0_training.bat
!start_continue_80e_736_clean_all_epoch140.bat
!firedetect_local_tune.py
